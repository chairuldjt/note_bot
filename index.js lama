const {
  default: makeWASocket,
  useMultiFileAuthState,
  DisconnectReason
} = require('@whiskeysockets/baileys')

const axios = require('axios')
const qrcode = require('qrcode-terminal')
const qs = require('qs')
require('dotenv').config({ path: '../.env' })

//Hanlder Sticker

const { downloadContentFromMessage } = require('@whiskeysockets/baileys')
const ffmpeg = require('fluent-ffmpeg')
const fs = require('fs')

const downloadMedia = async (message) => {
  const type = Object.keys(message)[0]
  const stream = await downloadContentFromMessage(message[type], type.replace('Message', ''))
  let buffer = Buffer.from([])
  for await (const chunk of stream) { buffer = Buffer.concat([buffer, chunk]) }
  return buffer
}

async function start() {
  const { state, saveCreds } = await useMultiFileAuthState('session')
  const sock = makeWASocket({
    auth: state
  })

  sock.ev.on('creds.update', saveCreds)

  sock.ev.on('connection.update', (update) => {
    const { connection, pairingCode, qr, lastDisconnect } = update
    if (qr) {
      qrcode.generate(qr, { small: true })
    }
    if (pairingCode) {
      console.log('PAIRING CODE:', pairingCode)
    }
    if (connection === 'close') {
      const shouldReconnect = lastDisconnect?.error?.output?.statusCode !== DisconnectReason.loggedOut
      if (shouldReconnect) {
        console.log('Connection closed, reconnecting...')
        setTimeout(() => start(), 5000)
      } else {
        console.log('Logged out, not reconnecting')
      }
    }
    if (connection === 'open') {
      console.log('BOT WHATSAPP TERHUBUNG ✅')

    }
  })


  sock.ev.on('messages.upsert', async ({ messages }) => {
    const msg = messages[0]
    if (!msg.message || msg.key.fromMe) return

    const text = msg.message.conversation || ''
    const from = msg.key.remoteJid
    const sender = msg.key.participant || from
    const nama = msg.pushName || 'User'

    // Fetch dynamic commands
    try {
      const commandsRes = await axios.get(process.env.API_BASE_URL + 'get_commands.php')
      const commands = commandsRes.data
      for (const cmd of commands) {
        if (text === cmd.command) {
          sock.sendMessage(from, { text: cmd.response })
          return
        }
      }
    } catch (e) {
      console.log('Error fetching commands:', e.message)
    }


    // --- FITUR STICKER (FINAL FIX) ---
    const mtype = Object.keys(msg.message)[0]
    const isQuoted = mtype === 'extendedTextMessage'

    // Ambil teks dari caption gambar atau teks reply
    const pesanTeks = msg.message?.conversation ||
      msg.message?.imageMessage?.caption ||
      msg.message?.extendedTextMessage?.text || ''

    if (pesanTeks.startsWith('/sticker')) {
      // Cek apakah pesan itu gambar langsung ATAU reply yang berisi gambar
      const imageMsg = msg.message?.imageMessage ||
        msg.message?.extendedTextMessage?.contextInfo?.quotedMessage?.imageMessage

      if (imageMsg) {
        // Bungkus kembali ke format yang dikenali fungsi downloadMedia Anda
        const downloadData = { imageMessage: imageMsg }

        try {
          const buffer = await downloadMedia(downloadData)
          const inputPath = `./temp_${Date.now()}.jpg`
          const outputPath = `./temp_${Date.now()}.webp`

          fs.writeFileSync(inputPath, buffer)

          ffmpeg(inputPath)
            .complexFilter(['scale=512:512:force_original_aspect_ratio=increase,fps=15,crop=512:512'])
            .on('end', async () => {
              await sock.sendMessage(from, { sticker: fs.readFileSync(outputPath) }, { quoted: msg })
              if (fs.existsSync(inputPath)) fs.unlinkSync(inputPath)
              if (fs.existsSync(outputPath)) fs.unlinkSync(outputPath)
            })
            .on('error', (e) => {
              console.error(e)
              sock.sendMessage(from, { text: '❌ Gagal konversi ffmpeg' })
            })
            .save(outputPath)
        } catch (e) {
          console.error(e)
          sock.sendMessage(from, { text: '❌ Gagal mendownload gambar' })
        }
        return
      } else {
        return sock.sendMessage(from, { text: '❌ Balas gambar atau kirim gambar dengan caption /sticker' })
      }
    }
    // --- AKHIR FITUR STICKER ---

    // TAMBAH KAS
    if (text.startsWith('/tambahkas')) {
      const parts = text.split(' ')
      if (parts.length < 3) {
        sock.sendMessage(from, { text: '❌ Format: /tambahkas <nama> <jumlah>' })
        return
      }
      const nama = parts[1]
      const jumlah = parseInt(parts[2])
      if (isNaN(jumlah) || jumlah <= 0) {
        sock.sendMessage(from, { text: '❌ Jumlah harus angka positif' })
        return
      }
      try {
        const res = await axios.post(process.env.API_BASE_URL + 'tambah_kas.php', qs.stringify({
          nomor: sender,
          nama: nama,
          jumlah: jumlah
        }), {
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' }
        })
        if (res.data.status === 'ok') {
          sock.sendMessage(from, { text: '✅ Kas ditambahkan' })
        } else {
          sock.sendMessage(from, { text: '❌ Gagal menambah kas' })
        }
      } catch (e) {
        sock.sendMessage(from, { text: '❌ Error: ' + e.message })
      }
    }

    // KURANGI KAS
    if (text.startsWith('/kurangikas')) {
      const parts = text.split(' ')
      if (parts.length < 3) {
        sock.sendMessage(from, { text: '❌ Format: /kurangikas <keperluantanpaspasi> <jumlah>' })
        return
      }
      const nama = parts[1]
      const jumlah = parseInt(parts[2])
      if (isNaN(jumlah) || jumlah <= 0) {
        sock.sendMessage(from, { text: '❌ Format: /kurangikas <keperluantanpaspasi> <jumlah>' })
        return
      }
      try {
        const res = await axios.post(process.env.API_BASE_URL + 'kurangi_kas.php', qs.stringify({
          nomor: sender,
          nama: nama,
          jumlah: -jumlah
        }), {
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' }
        })
        if (res.data.status === 'ok') {
          sock.sendMessage(from, { text: '✅ Kas dikurangi' })
        } else {
          sock.sendMessage(from, { text: '❌ Gagal mengurangi kas' })
        }
      } catch (e) {
        sock.sendMessage(from, { text: '❌ Error: ' + e.message })
      }
    }

    // HAPUS KAS
    if (text.startsWith('/hapus_kas')) {
      const parts = text.split(' ')
      if (parts.length < 2) {
        sock.sendMessage(from, { text: '❌ Format: /hapus_kas <id>' })
        return
      }
      const id = parseInt(parts[1])
      if (isNaN(id) || id <= 0) {
        sock.sendMessage(from, { text: '❌ ID harus angka positif' })
        return
      }
      try {
        const res = await axios.post(process.env.API_BASE_URL + 'hapus_kas.php', qs.stringify({
          id: id
        }), {
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' }
        })
        if (res.data.status === 'deleted') {
          sock.sendMessage(from, { text: '🗑️ Data kas dihapus' })
        } else {
          sock.sendMessage(from, { text: '❌ Gagal menghapus kas' })
        }
      } catch (e) {
        sock.sendMessage(from, { text: '❌ Error: ' + e.message })
      }
    }

    // CEK KAS (SUMMARY)
    if (text === '/cekkas') {
      const now = new Date()
      const bulan = (now.getMonth() + 1).toString().padStart(2, '0')
      const tahun = now.getFullYear()
      const bulanTahun = `${bulan}-${tahun}`
      const monthNames = ['Januari', 'Februari', 'Maret', 'April', 'Mei', 'Juni', 'Juli', 'Agustus', 'September', 'Oktober', 'November', 'Desember']
      const bulanNama = monthNames[now.getMonth()]

      try {
        // Fetch monthly data for the name list
        const resMonth = await axios.get(`${process.env.API_BASE_URL}rekap_bulan.php?bulan=${bulanTahun}`)
        // Fetch all-time data for Total and Last Update
        const resAll = await axios.get(`${process.env.API_BASE_URL}cek_kas.php`)

        const nameSet = new Set()
        const nameMap = new Map()
        resMonth.data.data.forEach(r => {
          if (r.jumlah > 0) {
            const lower = r.nama.toLowerCase()
            if (!nameSet.has(lower)) {
              nameSet.add(lower)
              nameMap.set(lower, r.nama)
            }
          }
        })
        const uniqueNames = Array.from(nameMap.values())
        let list = ''
        uniqueNames.forEach((name, index) => {
          list += `${index + 1}. ${name} ✅\n`
        })

        const lastUpdateAll = resAll.data.data.length > 0 ? new Date(Math.max(...resAll.data.data.map(r => new Date(r.tanggal)))).toLocaleDateString('id-ID') : 'Tidak ada data'
        const t = `💰 *TOTAL KAS TERKUMPUL*\n\nList Kas ${bulanNama} ${tahun}:\n${list}\nUpdate Terakhir: *${lastUpdateAll.replace(/\//g, '-')}*\nTotal Rp ${resAll.data.total.toLocaleString('id-ID')}`
        sock.sendMessage(from, { text: t })
      } catch (e) {
        sock.sendMessage(from, { text: '❌ Error: ' + e.message })
      }
    }

    // HISTORY KAS
    if (text === '/historykas') {
      try {
        const res = await axios.get(process.env.API_BASE_URL + 'cek_kas.php')
        let t = `💰 TOTAL KAS: Rp ${res.data.total.toLocaleString('id-ID')}\n\n`
        res.data.data.forEach(r => {
          const tanggal = new Date(r.tanggal).toLocaleDateString('id-ID')
          t += `#${r.id} ${r.nama} Rp ${r.jumlah.toLocaleString('id-ID')} (${tanggal})\n`
        })
        sock.sendMessage(from, { text: t })
      } catch (e) {
        sock.sendMessage(from, { text: '❌ Error: ' + e.message })
      }
    }


    // REKAP BULAN
    if (text.startsWith('/rekapbulan')) {
      const parts = text.split(' ')
      if (parts.length < 2) {
        sock.sendMessage(from, { text: '❌ Format: /rekapbulan <bulan-tahun> contoh: /rekapbulan 01-2026' })
        return
      }
      const bln = parts[1]
      if (!/^\d{2}-\d{4}$/.test(bln)) {
        sock.sendMessage(from, { text: '❌ Format bulan salah, gunakan MM-YYYY' })
        return
      }
      try {
        const res = await axios.get(
          `${process.env.API_BASE_URL}rekap_bulan.php?bulan=${bln}`
        )
        let t = `📆 REKAP ${bln}\nTotal: Rp ${res.data.total}\n\n`
        res.data.data.forEach(r => {
          t += `${r.nama} Rp ${r.jumlah}\n`
        })
        sock.sendMessage(from, { text: t })
      } catch (e) {
        sock.sendMessage(from, { text: '❌ Error: ' + e.message })
      }
    }
  })
}

start()
